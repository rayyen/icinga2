# Set defaults.
defaults
# Enable or disable TLS/SSL encryption.
tls off
tls_starttls off
tls_trust_file /etc/ssl/certs/ca-certificates.crt
# Setup WP account's settings.
account {ACCOUNT_ID}
host {YOUR_IPADDRESS}
port {PORT}
auth login
user {ACCOUNT}}
password {PASSWORD}
from {MAIL_FROM}
logfile /var/log/msmtp/msmtp.log
account default : {ACCOUNT_ID}